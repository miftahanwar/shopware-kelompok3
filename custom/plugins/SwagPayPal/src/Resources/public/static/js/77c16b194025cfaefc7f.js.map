export default "<sw-single-select\n    v-bind=\"$attrs\"\n    :value=\"value\"\n    :options=\"options\"\n    :error=\"invalidError\"\n    class=\"swag-paypal-settings-locale-select\"\n    @update:value=\"updateValue\"\n>\n    <template #result-label-property=\"{ item, highlightSearchTerm, searchTerm }\">\n        <span class=\"swag-paypal-settings-locale-select__locale_info\">\n            <sw-highlight-text\n                v-if=\"highlightSearchTerm && item.value !== value\"\n                :text=\"item.label\"\n                :search-term=\"searchTerm\"\n            />\n\n            <template v-else>\n                {{ item.label }}\n            </template>\n\n            <span\n                v-if=\"item.label !== item.dashed\"\n                class=\"swag-paypal-settings-locale-select__locale\"\n            >\n                {{ item.dashed }}\n            </span>\n        </span>\n    </template>\n</sw-single-select>\n";