export default "<sw-card\n    class=\"swag-paypal-settings-environment\"\n    position-identifier=\"swag-paypal-settings-environment\"\n    :title=\"$t('swag-paypal-settings.environment.title')\"\n    :is-loading=\"settingsStore.isLoading\"\n>\n    <span class=\"swag-paypal-settings-environment__info-text\">\n        {{ $t('swag-paypal-settings.environment.info') }}\n    </span>\n\n    <swag-paypal-setting path=\"SwagPayPal.settings.isLocalEnvironment\" />\n</sw-card>\n\n{% block swag_paypal_settings_webhook %}\n<swag-paypal-settings-webhook />\n{% endblock %}\n\n<sw-card\n    class=\"swag-paypal-settings-cross-border\"\n    position-identifier=\"swag-paypal-settings-cross-border\"\n    :title=\"$t('swag-paypal-settings.crossBorder.title')\"\n    :is-loading=\"settingsStore.isLoading\"\n>\n    <sw-alert class=\"swag-paypal-settings-cross-border__warning-text\" variant=\"warning\">\n        {{ $t('swag-paypal-settings.crossBorder.warning') }}\n    </sw-alert>\n\n    <span class=\"swag-paypal-settings-cross-border__info-text\">\n        {{ $t('swag-paypal-settings.crossBorder.info') }}\n    </span>\n\n    <swag-paypal-setting path=\"SwagPayPal.settings.crossBorderMessagingEnabled\" />\n\n    <swag-paypal-setting\n        path=\"SwagPayPal.settings.crossBorderBuyerCountry\"\n        :options=\"countryOverrideOptions\"\n    />\n</sw-card>\n";