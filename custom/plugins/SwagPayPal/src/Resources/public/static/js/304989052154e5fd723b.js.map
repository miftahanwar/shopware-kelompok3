export default "{% block sw_extension_card_base_context_menu_actions %}\n    <sw-context-menu-item\n            v-if=\"extension?.name === 'SwagPayPal'\"\n            :router-link=\"{ name: 'sw.settings.payment.overview' }\">\n        {{ $tc('sw-settings-payment.general.mainMenuItemGeneral') }}\n    </sw-context-menu-item>\n\n    <sw-context-menu-item\n            v-if=\"extension?.name === 'SwagPayPal'\"\n            :router-link=\"{ name: 'swag.paypal.index' }\">\n        {{ $tc('sw-extension-store.component.sw-extension-card-base.contextMenu.config') }}\n    </sw-context-menu-item>\n\n    <sw-context-menu-item\n        v-if=\"extension?.name === 'SwagPayPal'\"\n    >\n        <sw-external-link\n            as=\"a\"\n            target=\"_blank\"\n            href=\"https://github.com/shopware/SwagPayPal/issues\"\n        >\n            {{ $t('swag-paypal.extension-card-base.reportIssue') }}\n        </sw-external-link>\n    </sw-context-menu-item>\n\n    {% parent %}\n{% endblock %}\n";