export default "{% block sw_sales_channel_grid_columns_icon %}\n<sw-grid-column\n        v-if=\"isPayPalPosSalesChannel(item.id)\"\n        flex=\"85px\"\n        data-index=\"icon\"\n        class=\"sw-sales-channel-modal-grid__icon-column\"\n        label=\"icon\"\n>\n    <span\n        class=\"sw-sales-channel-modal-grid__icon\"\n        role=\"button\"\n        tabindex=\"0\"\n        @click=\"onOpenDetail(item.id)\"\n        @keydown.enter=\"onOpenDetail(item.id)\"\n    >\n         <img\n             class=\"swag-paypal-pos-modal-grid__icon\"\n             :src=\"assetFilter('swagpaypal/static/img/paypal-pos-logo.svg')\"\n         >\n    </span>\n</sw-grid-column>\n\n<template v-else>\n    {% parent %}\n</template>\n{% endblock %}\n\n";