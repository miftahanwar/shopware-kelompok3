export default "<a\n    :href=\"onboardingUrl\"\n    :disabled=\"isDisabled\"\n    :class=\"classes\"\n    class=\"swag-paypal-onboarding-button\"\n    target=\"_blank\"\n    :data-paypal-onboard-complete=\"callbackName\"\n    data-paypal-button=\"true\"\n>\n    <sw-loader\n        v-if=\"isLoading\"\n        class=\"sw-button_loader\"\n        size=\"20px\"\n    />\n\n    <slot>\n        {{ buttonTitle }}\n    </slot>\n</a>\n";