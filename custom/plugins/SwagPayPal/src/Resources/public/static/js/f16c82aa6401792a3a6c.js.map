export default "<div class=\"swag-paypal-merchant-information\">\n    <p class=\"swag-paypal-merchant-information__email\">\n        {{ merchantEmail }}\n        <br>\n        {{ merchantInformationStore.actual.merchantIntegrations.legal_name }}\n    </p>\n\n    <swag-paypal-setting\n        v-tooltip.left=\"{\n            message: tooltipSandbox,\n            disabled: !sandboxToggleDisabled,\n        }\"\n        path=\"SwagPayPal.settings.sandbox\"\n        class=\"swag-paypal-merchant-information__sandbox-toggle\"\n        :disabled=\"sandboxToggleDisabled\"\n        :bordered=\"false\"\n        @update:value=\"onSandboxToggle\"\n    />\n\n    <div class=\"swag-paypal-merchant-information__buttons\">\n        <slot />\n    </div>\n</div>\n";