export default "<sw-card\n    class=\"swag-paypal-local-environment\"\n    position-identifier=\"swag-paypal-local-environment\"\n    :title=\"$t('swag-paypal-settings.environment.title')\"\n    :is-loading=\"isLoading\"\n>\n    <span class=\"swag-paypal-local-environment__info-text\">\n        {{ $t('swag-paypal-settings.environment.info') }}\n    </span>\n\n    <swag-paypal-inherit-wrapper\n        v-bind=\"{ actualConfigData, allConfigs, selectedSalesChannelId }\"\n        path=\"SwagPayPal.settings.isLocalEnvironment\"\n    >\n        <template #content=\"props\">\n            <sw-switch-field\n                name=\"SwagPayPal.settings.isLocalEnvironment\"\n                :mapInheritance=\"props\"\n                :label=\"$tc('swag-paypal-setting.label.isLocalEnvironment')\"\n                :disabled=\"isLoading || props.isInherited || !acl.can('swag_paypal.editor')\"\n                :value=\"props.currentValue\"\n                bordered\n                @update:value=\"props.updateCurrentValue\"\n            />\n        </template>\n    </swag-paypal-inherit-wrapper>\n</sw-card>\n";